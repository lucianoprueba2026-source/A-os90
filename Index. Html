.mixto-inp { -webkit-appearance: none; }

/* ════════════════════════════════════════════════════════════
   VENTAS FASTFOOD LAYOUT — OVERRIDE COMPLETO
   Mobile-first. Botones siempre visibles. Sin fixed bar.
   NO modifica lógica JS. Conserva todos los IDs.
════════════════════════════════════════════════════════════ */

/* ── Contenedor raíz del POS ── */
.pos-container {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  overflow: hidden;
  background: var(--bg);
}

/* ── 1 · HEADER: stats bar ── */
.pos-header {
  flex-shrink: 0;
  display: flex;
  align-items: stretch;
  gap: 6px;
  padding: 5px 10px;
  overflow-x: auto;
  scrollbar-width: none;
  border-bottom: 1px solid var(--bd);
  background: var(--bg);
}
.pos-header::-webkit-scrollbar { display: none; }
/* Los pos-stat-pill que renderStats() inyecta quedan como flex items */

/* ── 2 · TICKET: carrito ── */
.pos-ticket {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg);
  border-bottom: 1px solid var(--bd);
  /* Cap máximo en mobile: garantiza que los botones siempre sean visibles */
  max-height: 38vh;
  max-height: 38svh;
}
.pos-ticket-topbar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6px 12px;
  border-bottom: 1px solid var(--bd);
  background: var(--bg);
}
.pos-ticket-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 6px 8px;
}

/* Carrito vacío: ultra-compacto */
.pos-ticket-scroll .pos-cart-empty {
  flex-direction: row !important;
  padding: 8px 12px !important;
  gap: 6px !important;
  min-height: 0 !important;
  justify-content: center;
}
.pos-ticket-scroll .pos-cart-empty-ico { font-size: 13px !important; opacity: 0.25 !important; }
.pos-ticket-scroll .pos-cart-empty-txt { font-size: 11px !important; color: var(--txt4) !important; text-align: left; }

/* ── 3 · TOTAL: override pos-total-area ── */
.pos-container .pos-total-area {
  flex-shrink: 0 !important;
  padding: 6px 14px 4px !important;
  border-bottom: 1px solid var(--bd) !important;
  background: var(--bg) !important;
}
.pos-container .pos-total-label { font-size: 7px !important; margin-bottom: 0 !important; }
.pos-container .pos-total-num   { font-size: 20px !important; margin-bottom: 2px !important; }
.pos-container .pos-total-rows  { font-size: 10px !important; gap: 1px !important; }
.pos-container .pos-tot-row     { padding: 0 !important; line-height: 1.25 !important; }

/* ── 4 · PAYMENTS: override pos-pay-area ── */
.pos-container .pos-pay-area {
  flex-shrink: 0 !important;
  padding: 6px 10px 7px !important;
  border-bottom: 1px solid var(--bd) !important;
  background: var(--bg) !important;
}
.pos-container .pos-pay-label  { font-size: 7.5px !important; margin-bottom: 5px !important; }
.pos-container .pos-pay-grid   { grid-template-columns: repeat(4,1fr) !important; gap: 4px !important; }
.pos-container .pos-pay-btn    { padding: 6px 3px !important; min-height: 36px !important; font-size: 9.5px !important; gap: 2px !important; }
.pos-container .pos-pay-ico    { font-size: 14px !important; }

/* Panel mixto compacto */
.pos-container .mixto-panel    { padding: 7px 10px 8px !important; }
.pos-container .mixto-row      { margin-bottom: 5px !important; gap: 5px !important; }
.pos-container .mixto-inp      { width: 82px !important; font-size: 12px !important; }

/* ── 5 · ACTIONS: SIEMPRE VISIBLES ──
   Override de todas las reglas que ocultan .pos-actions en mobile */
.pos-container .pos-actions {
  flex-shrink: 0 !important;
  display: flex !important;
  flex-direction: row !important;
  gap: 6px !important;
  padding: 7px 10px 9px !important;
  background: var(--bg) !important;
  border-top: 2px solid var(--bd) !important;
  box-shadow: 0 -3px 12px rgba(0,0,0,0.09) !important;
}
.pos-container .pos-confirm-btn {
  min-height: 40px !important;
  font-size: 13px !important;
  border-radius: 10px !important;
  padding: 0 10px !important;
}

/* ── Fixed bar: ya no necesaria, ocultar ── */
#pos-fixed-action-bar  { display: none !important; }

/* ── padding-bottom del tab ya no necesario ── */
#tab-ventas { padding-bottom: 0 !important; }

/* ── Desktop ≥769px: grid 2 columnas ── */
@media (min-width: 769px) {
  .pos-container {
    display: grid;
    grid-template-columns: 1fr 320px;
    grid-template-rows: auto 1fr auto auto auto;
    grid-template-areas:
      "header   header  "
      "ticket   total   "
      "ticket   payments"
      "ticket   actions ";
    height: 100%;
    overflow: hidden;
  }
  .pos-header               { grid-area: header; }
  .pos-ticket               { grid-area: ticket; border-right: 1px solid var(--bd); border-bottom: none; max-height: none; }
  .pos-container .pos-total-area   { grid-area: total;    align-self: start; padding: 14px 16px 10px !important; background: var(--bg2) !important; }
  .pos-container .pos-pay-area     { grid-area: payments; padding: 10px 14px 12px !important; background: var(--bg2) !important; }
  .pos-container .pos-actions      { grid-area: actions;  padding: 10px 14px 14px !important; background: var(--bg2) !important; border-top: 1px solid var(--bd) !important; }

  .pos-container .pos-total-num  { font-size: 28px !important; }
  .pos-container .pos-pay-grid   { grid-template-columns: 1fr 1fr !important; gap: 5px !important; }
  .pos-container .pos-pay-btn    { padding: 9px 6px !important; min-height: 44px !important; font-size: 10px !important; }
  .pos-ticket-scroll             { padding: 10px 12px; }
}



/* ══ HEADER ACTION BUTTONS CON LABEL ══ */
.hdr-actions {
  display: flex; gap: 2px; margin-left: 8px;
  flex-shrink: 0; align-items: center;
}
.hdr-act {
  display: flex; flex-direction: column; align-items: center; gap: 1px;
  background: rgba(255,255,255,0.10); color: #fff; border: none;
  border-radius: 7px; padding: 4px 7px; cursor: pointer;
  font-family: 'Figtree', sans-serif; transition: background 0.15s;
  min-width: 40px; line-height: 1;
}
.hdr-act:hover  { background: rgba(255,255,255,0.20); }
.hdr-act:active { transform: scale(0.92); }
.hdr-act-ico { font-size: 15px; line-height: 1; }
.hdr-act-lbl {
  font-size: 7.5px; font-weight: 700; letter-spacing: 0.06em;
  text-transform: uppercase; color: rgba(255,255,255,0.68);
  white-space: nowrap;
}
.hdr-act-danger { background: rgba(220,38,38,0.22); }
.hdr-act-danger:hover { background: rgba(220,38,38,0.38); }
.hdr-act-danger .hdr-act-lbl { color: #fca5a5; }
@media (max-width: 680px) {
  .hdr-act { min-width: 30px; padding: 4px 5px; }
  .hdr-act-lbl { display: none; }
}

/* ══ GENDER BADGE — inicial con color, sin emoji ══ */
.g-badge {
  display: inline-flex; align-items: center; justify-content: center;
  width: 22px; height: 22px; border-radius: 5px;
  font-size: 11px; font-weight: 900;
  font-family: 'Outfit', sans-serif;
  flex-shrink: 0; line-height: 1; letter-spacing: -0.02em;
}
.g-h { background: var(--blue-bg); color: var(--blue); }
.g-m { background: var(--pur-bg);  color: var(--purple); }
.g-u { background: var(--ok-bg);   color: var(--ok); }
.g-a { background: var(--bg3);     color: var(--txt3); font-size: 9px; }



/* ══════════════════════════════════════════════
   PROD-ROW COMPACTO — layout limpio, 2 filas
   Desktop: fila única con padding reducido
   Mobile:  fila1=badge+nombre+precios | fila2=badges+botones
══════════════════════════════════════════════ */

/* ── Desktop: solo reducir padding ── */
.prod-row {
  padding: 7px 14px !important;
  gap: 10px !important;
  flex-wrap: nowrap !important;
  align-items: center !important;
}
.prod-row .pr-name { font-size: 13px !important; }
.prod-row .pr-meta { margin-top: 2px !important; }
.prod-row .pr-meta .badge { font-size: 8.5px !important; padding: 1px 6px !important; }
.prod-row .pr-price-val  { font-size: 13px !important; }
.prod-row .pr-price-tag  { font-size: 7.5px !important; }
.prod-row .pr-price-block { min-width: 64px !important; }
.prod-row .pr-actions .btn-sm { min-height: 30px !important; padding: 4px 9px !important; }

/* ── Mobile ≤680px: layout 2 filas limpio ── */
@media (max-width: 680px) {
  .prod-row {
    flex-wrap: wrap !important;
    padding: 7px 10px !important;
    column-gap: 6px !important;
    row-gap: 3px !important;
    align-items: center !important;
  }

  /* Badge M: centrado verticalmente, no crece */
  .prod-row .pr-ico {
    flex-shrink: 0 !important;
    align-self: center !important;
    margin-top: 0 !important;
    width: auto !important;
  }

  /* Info: crece, nombre en 1 línea truncado */
  .prod-row .pr-info {
    flex: 1 1 0 !important;
    min-width: 0 !important;
    display: block !important;
  }
  .prod-row .pr-name {
    font-size: 13px !important;
    white-space: nowrap !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
    display: block !important;
    line-height: 1.3 !important;
    -webkit-line-clamp: unset !important;
  }
  .prod-row .pr-meta {
    display: flex !important;
    gap: 3px !important;
    margin-top: 2px !important;
    flex-wrap: nowrap !important;
    overflow: hidden !important;
    max-width: 100% !important;
  }
  .prod-row .pr-meta .badge {
    font-size: 8px !important;
    padding: 1px 5px !important;
    flex-shrink: 1 !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
    white-space: nowrap !important;
    max-width: 110px !important;
  }

  /* Precios: lado derecho fila 1, compactos */
  .prod-row .pr-prices {
    flex-shrink: 0 !important;
    gap: 8px !important;
    align-self: center !important;
    align-items: flex-end !important;
  }
  .prod-row .pr-price-block { min-width: 54px !important; text-align: right !important; }
  .prod-row .pr-price-val   { font-size: 12px !important; }
  .prod-row .pr-price-tag   { font-size: 7px !important; margin-top: 0 !important; }

  /* Acciones: segunda fila completa, botones a la derecha */
  .prod-row .pr-actions {
    flex: 0 0 100% !important;
    width: 100% !important;
    justify-content: flex-end !important;
    flex-wrap: nowrap !important;
    gap: 4px !important;
    margin-top: 0 !important;
  }
  .prod-row .pr-actions .btn-sm {
    min-height: 28px !important;
    font-size: 11px !important;
    padding: 4px 9px !important;
    flex-shrink: 0 !important;
  }
}

/* ── Logo marca en header ── */
.hdr-brand-logo {
  display: none;
}


/* ── Dirección en login ── */
.login-address {
  text-align: center;
  margin: -10px 0 18px;
  color: var(--txt3);
  font-family: 'Outfit', sans-serif;
}
.login-address p {
  margin: 2px 0;
  font-size: 12px;
  letter-spacing: 0.01em;
  line-height: 1.5;
}

/* ── Dirección en header ── */
.hdr-address-bar {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 1px;
  flex: 1;
  min-width: 0;
  padding: 0 10px;
  overflow: hidden;
}
.hdr-address-bar span {
  font-size: 9px;
  color: rgba(255,255,255,0.65);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
}
/* En mobile mostramos solo el teléfono */
@media (max-width: 680px) {
  .hdr-address-bar .addr-full { display: none; }
  .hdr-address-bar .addr-phone {
    font-size: 10px;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
  }
}
@media (min-width: 681px) {
  .hdr-address-bar .addr-phone { display: none; }
}

/* ── Reportes: barra de filtro de fechas ── */
.rep-filter-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 20px;
  background: var(--bg2);
  border-bottom: 1px solid var(--bd);
  flex-wrap: wrap;
}
.rep-filter-lbl {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--txt3);
  font-weight: 600;
}
.rep-date-inp {
  border: 1px solid var(--bd2);
  border-radius: 8px;
  padding: 4px 8px;
  font-size: 12px;
  background: var(--bg);
  color: var(--txt);
}

/* ── PDF Catálogo: overlay de impresión ── */
#catalog-print-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: #fff;
  z-index: 9999;
  overflow-y: auto;
  padding: 24px;
}
@media print {
  body > *:not(#catalog-print-overlay) { display: none !important; }
  #catalog-print-overlay { display: block !important; position: static; }
}

/* ═══════════════════════════════════════════════════════════════
   ÉXTASIS · Y2K FASHION EDITION · PINK & LILAC
   Gradientes holo · radius redondeados · sombras coloreadas
═══════════════════════════════════════════════════════════════ */

/* — Tipografía display: Sora bold para títulos — */
.brand-name, .brand-tagline, .login-tagline,
.kpi-val, .kpi-num, .pos-checkout-total-val,
.checkout-total-val, .pos-stat-val, .stat-val,
.modal-title, .login-title, .total-val,
.report-stat-val, h1, h2, h3 {
  font-family: var(--font-display) !important;
  font-weight: 700;
  letter-spacing: -0.015em;
}

.brand-name, .login-title {
  font-weight: 800 !important;
  background: linear-gradient(135deg, var(--ac) 0%, var(--purple) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* — Body / botones — */
.btn, .btn-primary, .btn-secondary, .btn-confirm,
.btn-confirm-sale, .login-enter, .tab-btn,
.method-btn, .filter-chip, .hdr-act, .nav-item,
.btn-add, .btn-edit, .btn-del, .btn-action {
  font-family: var(--font-body) !important;
  font-weight: 600 !important;
  letter-spacing: 0.01em;
}

.kpi-lbl {
  font-weight: 600 !important;
  color: var(--txt3) !important;
  font-size: 0.78em !important;
  letter-spacing: 0.04em;
}

/* — Mono Y2K — */
.price, .total, .kpi-val, .pos-stat-val,
.cart-item-price, .checkout-total-val,
.pos-checkout-total-val, .stat-val, .num,
input[type="number"], input[type="date"],
.rep-date-inp, td.num, .cell-num {
  font-family: var(--font-mono) !important;
  font-variant-numeric: tabular-nums;
  font-weight: 700;
}

/* — RADIUS muy redondeados — */
.kpi-card, .dash-card, .modal, .panel, .card,
.product-card, .pos-product-card, .cart-item,
.btn, .btn-primary, .btn-secondary,
.tab-btn, .method-btn, .filter-chip, .badge, .g-badge,
.toast, .empty-state, .login-card, .login-box,
.cat-item, .nav-item, .hdr-act, .pos-checkout-panel,
.pos-cart, .checkout-panel, .sales-panel, .prod-grid-item {
  border-radius: 18px !important;
}

input, select, textarea, .input {
  border-radius: 14px !important;
}

/* — Bordes rosa pálido — */
.kpi-card, .dash-card, .product-card, .pos-product-card,
.modal, .toast, .login-card, .login-box,
input, select, textarea, .tab-btn, .method-btn,
.filter-chip, .pos-cart, .checkout-panel, .pos-checkout-panel {
  border: 1.5px solid var(--bd) !important;
}

/* — Sombras coloreadas rosa — */
.kpi-card, .dash-card, .product-card, .pos-product-card {
  box-shadow: var(--sh) !important;
}

.kpi-card:hover, .dash-card:hover {
  box-shadow: var(--shm) !important;
  border-color: var(--ac) !important;
  transform: translateY(-2px) !important;
}

/* — HEADER #hdr: gradiente fucsia → lila — */
#hdr, header.app-header {
  background: linear-gradient(135deg, #EC4899 0%, #A855F7 50%, #C084FC 100%) !important;
  background-image: linear-gradient(135deg, #EC4899 0%, #A855F7 50%, #C084FC 100%) !important;
  border-bottom: none !important;
  box-shadow: 0 4px 20px rgba(236,72,153,0.30) !important;
}

#hdr .brand-name, #hdr .brand-tagline,
#hdr .login-address, header.app-header .brand-name {
  color: #FFF !important;
  -webkit-text-fill-color: #FFF !important;
  background: none !important;
}

[data-theme="dark"] #hdr {
  background: linear-gradient(135deg, #6B21A8 0%, #DB2777 100%) !important;
  background-image: linear-gradient(135deg, #6B21A8 0%, #DB2777 100%) !important;
}

/* — Stats bar suave — */
.pos-header {
  background: var(--bg2) !important;
  background-image:
    linear-gradient(135deg, rgba(236,72,153,0.04) 0%, rgba(168,85,247,0.04) 100%) !important;
  border-bottom: 1px solid var(--bd) !important;
}

/* — LOGIN Y2K dreamy — */
.login-screen, #login-screen {
  background: var(--bg) !important;
  background-image:
    radial-gradient(circle at 15% 20%, rgba(236,72,153,0.20) 0%, transparent 45%),
    radial-gradient(circle at 85% 75%, rgba(168,85,247,0.20) 0%, transparent 45%),
    radial-gradient(circle at 50% 100%, rgba(6,182,212,0.10) 0%, transparent 50%) !important;
}

.login-card, .login-box {
  background: rgba(255,255,255,0.7) !important;
  backdrop-filter: blur(20px) !important;
  -webkit-backdrop-filter: blur(20px) !important;
  border: 1.5px solid rgba(236,72,153,0.25) !important;
  box-shadow: var(--shl) !important;
}

[data-theme="dark"] .login-card,
[data-theme="dark"] .login-box {
  background: rgba(37,16,64,0.75) !important;
  border: 1.5px solid rgba(244,114,182,0.30) !important;
}

.login-title {
  font-family: var(--font-display) !important;
  font-weight: 800 !important;
  font-size: 2em !important;
}

.login-enter, .btn-login, button[type="submit"].login-enter {
  background: linear-gradient(135deg, var(--ac) 0%, var(--purple) 100%) !important;
  color: #FFF !important;
  border: none !important;
  font-weight: 700 !important;
  letter-spacing: 0.05em !important;
  box-shadow: 0 4px 16px rgba(236,72,153,0.35) !important;
}

.login-enter:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(236,72,153,0.45) !important;
}

/* — KPI cards: fondo blanco con halo de color rotado — */
.kpi-card, .dash-card {
  background: var(--bg2) !important;
  position: relative;
  overflow: hidden;
}

.kpi-card::before {
  content: '';
  position: absolute;
  top: -2px; left: -2px; right: -2px;
  height: 4px;
  background: linear-gradient(90deg, var(--ac) 0%, var(--purple) 100%);
  border-radius: 18px 18px 0 0;
}

.kpi-card:nth-child(2n)::before {
  background: linear-gradient(90deg, var(--purple) 0%, var(--blue) 100%);
}
.kpi-card:nth-child(3n)::before {
  background: linear-gradient(90deg, var(--blue) 0%, var(--ac) 100%);
}
.kpi-card:nth-child(4n)::before {
  background: linear-gradient(90deg, var(--ac3) 0%, var(--ora) 100%);
}

.kpi-card .kpi-val {
  font-weight: 800 !important;
}

.kpi-card.kpi-accent {
  background: linear-gradient(135deg, var(--ac) 0%, var(--purple) 100%) !important;
  border-color: transparent !important;
}

.kpi-card.kpi-accent .kpi-lbl,
.kpi-card.kpi-accent .kpi-val {
  color: #FFF !important;
}

.kpi-card.kpi-danger .kpi-val {
  color: var(--err) !important;
}

/* — Tabs Y2K — */
.tab-btn {
  background: var(--bg2) !important;
  color: var(--txt3) !important;
  border: 1.5px solid var(--bd) !important;
  font-weight: 600 !important;
}

.tab-btn.active {
  background: linear-gradient(135deg, var(--ac) 0%, var(--purple) 100%) !important;
  color: #FFF !important;
  border-color: transparent !important;
  box-shadow: 0 4px 12px rgba(236,72,153,0.30) !important;
}

/* — Filter chips Y2K — */
.filter-chip, .cat-item {
  background: var(--bg2) !important;
  color: var(--txt) !important;
  border: 1.5px solid var(--bd) !important;
  font-weight: 600 !important;
}

.filter-chip.active, .cat-item.active {
  background: linear-gradient(135deg, var(--ac) 0%, var(--purple) 100%) !important;
  color: #FFF !important;
  border-color: transparent !important;
}

/* — Botones Y2K — */
.btn-primary {
  background: linear-gradient(135deg, var(--ac) 0%, var(--purple) 100%) !important;
  color: #FFF !important;
  border: none !important;
  font-weight: 700 !important;
  box-shadow: 0 4px 14px rgba(236,72,153,0.30) !important;
  transition: all 0.2s ease !important;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(236,72,153,0.40) !important;
}

.btn-confirm, .btn-confirm-sale {
  background: linear-gradient(135deg, var(--ok) 0%, var(--ok2) 100%) !important;
  color: #FFF !important;
  border: none !important;
  font-weight: 700 !important;
  box-shadow: 0 4px 14px rgba(16,185,129,0.30) !important;
}

.btn-confirm:hover, .btn-confirm-sale:hover {
  transform: translateY(-2px);
}

.btn-secondary {
  background: var(--bg2) !important;
  color: var(--txt) !important;
  border: 1.5px solid var(--bd) !important;
  font-weight: 600 !important;
}

.btn-secondary:hover {
  border-color: var(--ac) !important;
  color: var(--ac) !important;
}

.btn-del, .btn-danger {
  background: linear-gradient(135deg, var(--err) 0%, var(--ora) 100%) !important;
  color: #FFF !important;
  border: none !important;
  font-weight: 600 !important;
  box-shadow: 0 4px 14px rgba(244,63,94,0.25) !important;
}

/* — Inputs Y2K — */
input:not([type="checkbox"]):not([type="radio"]),
select, textarea {
  background: var(--bg2) !important;
  border: 1.5px solid var(--bd) !important;
  font-family: var(--font-body) !important;
  font-weight: 500 !important;
}

input:focus, select:focus, textarea:focus {
  outline: none !important;
