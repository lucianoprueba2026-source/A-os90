  S.products = []; S.categorias = JSON.parse(JSON.stringify(INIT_CATEGORIAS)); S.subcategorias = {};
  S.sales = []; S.expenses = []; S.cart = [];
  save(); closeModal(); renderAll();
  toast("Sistema limpiado. Listo para trabajar 🚀", "ok");
}

function doResetSalesOnly() {
  if (!confirm("¿Borrar todas las ventas y gastos? Los productos se conservan.")) return;
  S.sales = []; S.expenses = []; S.cart = [];
