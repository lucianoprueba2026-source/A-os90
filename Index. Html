/* helpers para filter drawer — evitan conflicto de comillas en onclick */
function fdrSetCat(cat) {
  S.catFilter = cat; S.subFilter = 'Todas'; S.subcatFilter = 'Todas';
  renderFilterDrawer();
}
function fdrSetSub(sub) {
  S.subFilter = sub; S.subcatFilter = 'Todas';
  renderFilterDrawer();
}
function fdrSetSubcat(sc) {
  S.subcatFilter = sc;
  renderFilterDrawer();
}

function renderFilterDrawer() {
  /* Gender */
  var gEl = document.getElementById('fdrawer-gender');
  if (gEl) {
    var gdata = [
      {key:'Todos',  cls:'g-a', lbl:'Todos',  badge:'ALL'},
      {key:'Hombre', cls:'g-h', lbl:'Hombre', badge:'H'},
      {key:'Mujer',  cls:'g-m', lbl:'Mujer',  badge:'M'},
      {key:'Accesorios', cls:'g-u', lbl:'Accesorios', badge:'A'}
    ];
    gEl.innerHTML = gdata.map(function(g) {
      var a = S.catFilter === g.key ? 'active' : '';
      return '<button class="filter-chip ' + a + '" onclick="fdrSetCat(\'' + g.key + '\')">' +
             '<span class="g-badge ' + g.cls + '" style="width:18px;height:18px;font-size:10px;border-radius:4px;display:inline-flex;align-items:center;justify-content:center;vertical-align:middle;margin-right:4px;">' + g.badge + '</span>' +
             g.lbl + '</button>';
    }).join('');
  }
  /* Category */
  var cEl = document.getElementById('fdrawer-cat');
  if (cEl) {
    var vis = S.products.filter(function(p) {
      return S.catFilter === 'Todos' || p.nombre === S.catFilter;
    });
    var used = [];
    vis.forEach(function(p) {
      if (p.categoria && !used.includes(p.categoria)) used.push(p.categoria);
    });
    var avail = S.categorias.filter(function(s) { return used.includes(s); });
    var chips = '<button class="filter-chip ' + (S.subFilter === 'Todas' ? 'active' : '') +
                '" onclick="fdrSetSub(\'Todas\')">Todas</button>';
    avail.forEach(function(s) {
      var a = S.subFilter === s ? 'active' : '';
      chips += '<button class="filter-chip ' + a + '" onclick="fdrSetSub(\'' + s + '\')">' + s + '</button>';
    });
    cEl.innerHTML = chips;
  }
  /* Subcategory */
  var scSec = document.getElementById('fdrawer-subcat-section');
  var scEl  = document.getElementById('fdrawer-subcat');
  if (scEl && scSec) {
    var subs = (S.subFilter !== 'Todas') ? (S.subcategorias[S.subFilter] || []) : [];
    if (subs.length) {
      scSec.style.display = 'block';
      var sc = '<button class="filter-chip ' + (S.subcatFilter === 'Todas' ? 'active' : '') +
               '" onclick="fdrSetSubcat(\'Todas\')">Todas</button>';
      subs.forEach(function(s) {
        var a = S.subcatFilter === s ? 'active' : '';
        sc += '<button class="filter-chip ' + a + '" onclick="fdrSetSubcat(\'' + s + '\')">' + s + '</button>';
      });
      scEl.innerHTML = sc;
    } else {
      scSec.style.display = 'none';
    }
  }
  updateFilterDot();
}


