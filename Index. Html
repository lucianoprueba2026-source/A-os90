/* ─── Helpers HTTP ─── */
async function supaGET(table, params) {
  var url = SUPA_URL + "/rest/v1/" + table + "?" + (params||"select=*&order=id.asc");
  var r = await fetch(url, { headers: { "apikey": SUPA_KEY, "Authorization": "Bearer " + SUPA_KEY } });
  return r.ok ? r.json() : [];
}

async function supaUPSERT(table, rows) {
  if (!rows || !rows.length) return;
  await fetch(SUPA_URL + "/rest/v1/" + table, {
    method: "POST",
    headers: { "apikey": SUPA_KEY, "Authorization": "Bearer " + SUPA_KEY,
                "Content-Type": "application/json", "Prefer": "resolution=merge-duplicates" },
    body: JSON.stringify(rows)
  });
}

async function supaDELETE(table, id) {
  await fetch(SUPA_URL + "/rest/v1/" + table + "?id=eq." + id, {
    method: "DELETE",
    headers: { "apikey": SUPA_KEY, "Authorization": "Bearer " + SUPA_KEY }
  });
}

/* ─── Convertir sale → fila Supabase ─── */
function saleToRow(s) {
  return {
    id: s.id, terminal: s.terminal||"principal",
    date: s.date, time: s.time, method: s.method,
    base_total: s.baseTotal||0, discount: s.discount||0, total: s.total,
    items: s.items||[], mixto_breakdown: s.mixtoBreakdown||null,
    credito_cuotas: s.creditoCuotas||1
  };
}
function rowToSale(r) {
  return {
    id: r.id, terminal: r.terminal||"principal",
    date: r.date, time: r.time, method: r.method,
    baseTotal: r.base_total, discount: r.discount, total: r.total,
    items: r.items||[], mixtoBreakdown: r.mixto_breakdown||null,
    creditoCuotas: r.credito_cuotas||1
  };
}
function expToRow(e) {
  return { id: e.id, terminal: e.terminal||"principal",
            date: e.date, descripcion: e.desc, amount: e.amount };
}
function rowToExp(r) {
  return { id: r.id, terminal: r.terminal||"principal",
            date: r.date, desc: r.descripcion, amount: r.amount };
}
function prodToRow(p) {
  return { id: p.id, producto: p.producto||p.name||"",
            nombre: p.nombre||"Accesorios", categoria: p.categoria||"",
            subcategoria: p.subcategoria||"", precio: p.precio||0 };
}
function rowToProd(r) {
  return { id: r.id, producto: r.producto, nombre: r.nombre,
            categoria: r.categoria, subcategoria: r.subcategoria, precio: r.precio };
}

/* ─── Sincronizar desde la nube al arrancar ─── */
async function syncFromCloud() {
  try {
    var [prods, sales, exps] = await Promise.all([
      supaGET("ex_products"),
      supaGET("ex_sales", "select=*&order=id.desc&limit=1000"),
      supaGET("ex_expenses", "select=*&order=id.desc&limit=500")
    ]);
    if (prods && prods.length) {
      S.products = prods.map(rowToProd);
      lsW("ex2_prods", S.products);
    }
    if (sales && sales.length) {
      S.sales = sales.map(rowToSale);
      lsW("ex2_sales", S.sales);
    }
    if (exps && exps.length) {
      S.expenses = exps.map(rowToExp);
      lsW("ex2_expenses", S.expenses);
    }
    renderAll();
    console.log("✓ Sync cloud→local: prods=" + (prods&&prods.length) + " sales=" + (sales&&sales.length));
  } catch(e) {
    console.warn("syncFromCloud error:", e);
  }
}

/* ─── Push local → cloud ─── */
async function pushSaleToCloud(sale) {
  try { await supaUPSERT("ex_sales", [saleToRow(sale)]); } catch(e) { console.warn("pushSale:", e); }
}
async function pushExpenseToCloud(exp) {
  try { await supaUPSERT("ex_expenses", [expToRow(exp)]); } catch(e) { console.warn("pushExp:", e); }
}
async function pushProductsToCloud() {
  try {
    var rows = S.products.map(prodToRow);
    if (rows.length) await supaUPSERT("ex_products", rows);
  } catch(e) { console.warn("pushProds:", e); }
}
async function deleteProductFromCloud(id) {
  try { await supaDELETE("ex_products", id); } catch(e) { console.warn("deleteProd:", e); }
}

/* ─── Realtime: ventas de otras terminales ─── */
function subscribeRealtime() {
  try {
    realtimeChannel = supaClient.channel("extasis_sales")
      .on("postgres_changes", {
        event: "INSERT", schema: "public", table: "ex_sales"
      }, function(payload) {
        var newSale = rowToSale(payload.new);
        // Solo agregar si no es nuestra propia venta
        var exists = S.sales.find(function(s){ return s.id === newSale.id; });
        if (!exists) {
          S.sales.unshift(newSale);
          lsW("ex2_sales", S.sales);
          renderAll();
          toast("🔔 Nueva venta desde terminal secundaria: " + fmt(newSale.total), "ok");
        }
      })
      .subscribe();
    console.log("✓ Realtime subscrito");
  } catch(e) {
    console.warn("Realtime error:", e);
  }
}

