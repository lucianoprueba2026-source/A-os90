/* ══════════════════════════════════════
   CALCULATIONS
══════════════════════════════════════ */
function todaySales() { return S.sales.filter(s => s.date === mkToday()); }

function monthSales() {
  const now = new Date(); const m = now.getMonth(); const y = now.getFullYear();
  return S.sales.filter(s => {
    const p = s.date.split("/");
    if (p.length < 3) return false;
    const d = new Date(parseInt(p[2]), parseInt(p[1])-1, parseInt(p[0]));
    return d.getMonth() === m && d.getFullYear() === y;
  });
}

function topProducts(limit) {
  limit = limit || 8;
  const map = {};
  S.sales.forEach(s => {
    s.items.forEach(item => {
      if (!map[item.name]) map[item.name] = { name:item.name, qty:0, total:0 };
      map[item.name].qty  += item.qty;
      map[item.name].total += item.price * item.qty;
    });
  });
  return Object.values(map).sort((a,b) => b.qty - a.qty).slice(0, limit);
}

function calcStats() {
  var ts = todaySales();
  var totalVentas    = ts.reduce(function(a,s){ return a + s.total; }, 0);
  var totalTransfer  = 0;
  var totalDebito    = 0;
  var totalCredito   = 0;

  ts.forEach(function(s) {
    if (s.method === "Transferencia") {
      totalTransfer += s.total;
    } else if (s.method === "Débito") {
      totalDebito += s.total;
    } else if (s.method === "Crédito") {
      totalCredito += s.total;
    } else if (s.method === "Mixto") {
      if (s.mixtoBreakdown) {
        var mb = s.mixtoBreakdown;
        totalTransfer += (mb.transferencia || 0);
        totalDebito   += (mb.debito        || 0);
        totalCredito  += (mb.credito       || 0);
      } else {
        totalDebito += s.total; /* legado sin desglose */
      }
    }
    /* Efectivo puro: no suma */
  });

  var totalTransf  = totalTransfer + totalDebito + totalCredito; /* compat */
  var totalGastos  = S.expenses.filter(function(e){ return e.date === mkToday(); })
                                .reduce(function(a,e){ return a + e.amount; }, 0);
  var efectivo = totalVentas - totalTransf - totalGastos;
  return { totalVentas, totalTransf, totalTransfer, totalDebito, totalCredito, totalGastos, efectivo };
}

function cartCalc() {
  const base = S.cart.reduce((a,i) => a + i.price * i.qty, 0);
  const disc = (S.method === "Efectivo" || S.method === "Transferencia") ? Math.round(base * DISCOUNT) : 0;
  return { base, disc, total: base - disc };
}

