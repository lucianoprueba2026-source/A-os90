    '<div class="dash-grid-2">' +
      '<div class="dash-card"><div class="dash-card-hdr"><span class="dash-card-ttl">Ventas por método de pago</span></div>' +
      (function(){
        var ttls  = { Efectivo:0, Transferencia:0, Debito:0, Credito:0, Mixto:0 };
        var cnts  = { Efectivo:0, Transferencia:0, Debito:0, Credito:0, Mixto:0 };
        ts.forEach(function(s) {
          if (s.method === 'Mixto') {
            cnts.Mixto++; ttls.Mixto += s.total;
            if (s.mixtoBreakdown) {
              var mb = s.mixtoBreakdown;
              ttls.Efectivo      += (mb.efectivo      || 0);
              ttls.Transferencia += (mb.transferencia || 0);
              ttls.Debito        += (mb.debito || 0);
              ttls.Credito       += (mb.credito || 0);
            }
          } else if (s.method === 'Efectivo') {
            cnts.Efectivo++; ttls.Efectivo += s.total;
          } else if (s.method === 'Transferencia') {
            cnts.Transferencia++; ttls.Transferencia += s.total;
          } else if (s.method === 'Débito') {
            cnts.Debito++; ttls.Debito += s.total;
          } else if (s.method === 'Crédito') {
            cnts.Credito++; ttls.Credito += s.total;
          }
        });
        var MDEF = [
          { key:'Efectivo',      kk:'Efectivo',      icon:'💵' },
          { key:'Transferencia', kk:'Transferencia', icon:'📲' },
          { key:'Débito',        kk:'Debito',        icon:'💳' },
          { key:'Crédito',       kk:'Credito',       icon:'🏦' },
          { key:'Mixto',         kk:'Mixto',         icon:'⚡' },
        ];
        var items = MDEF.map(function(m) {
