function addToCart(prod) {
  var ex = S.cart.find(function(i){ return i.id === prod.id; });
  if (ex) ex.qty++;
  else S.cart.push({ id:prod.id, name:prod.producto, price:prod.precio, qty:1 });
  goVentas();
  renderCheckout();
  toast("✓ " + prod.name + " agregado", "ok");
}

function updQty(id, delta) {
  const item = S.cart.find(i => i.id === id);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) S.cart.splice(S.cart.indexOf(item), 1);
  renderCheckout();
}

function delItem(id) {
  S.cart = S.cart.filter(i => i.id !== id);
  renderCheckout();
}

function clearCart() { S.cart = []; renderCheckout(); }

function setMethod(key) {
  S.method = key;
  if (key !== 'Mixto') {
    S.mixtoDistrib = { efectivo:0, transferencia:0, debito:0, credito:0 };
  }
  if (key !== 'Crédito') {
    S.creditoCuotas = 1;
  }
