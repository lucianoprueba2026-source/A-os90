  }
  /* ★ BOTONES DE PAGO — reducidos para que los 4 entren en pantalla ★ */
  .pos-pay-btn {
    padding: 6px 4px !important;
    min-height: 38px !important;
    font-size: 10px !important;
    gap: 2px !important;
  }
  .pos-pay-ico {
    font-size: 15px !important;
  }
  /* ★ FIX CRÍTICO: Invertir flex para que el checkout SIEMPRE tenga espacio ★
     El carrito tiene altura máxima fija → el checkout llena lo que sobra       */
  .pos-cart-panel {
    flex: 0 0 auto !important;      /* NO crece más allá de su contenido */
    max-height: 26vh !important;    /* techo: nunca ocupa más del 26% de pantalla */
    min-height: 38px !important;
    overflow-y: auto !important;    /* si hay muchos ítems, hace scroll interno */
    -webkit-overflow-scrolling: touch !important;
    border-right: none !important;
    border-bottom: 1px solid var(--bd) !important;
