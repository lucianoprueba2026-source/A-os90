/* ══ PDF CATÁLOGO ══ */
function closeCatalogPrint() {
  document.getElementById('catalog-print-overlay').style.display = 'none';
}

function exportCatalogoPDF() {
  var prods = S.products;
  if (!prods || !prods.length) { toast("No hay productos para exportar", "warn"); return; }

  // Agrupar por campo 'nombre' (Hombre / Mujer / Accesorios)
  var grupos = {};
  prods.forEach(function(p) {
    var g = p.nombre || 'Accesorios';
    if (!grupos[g]) grupos[g] = [];
    grupos[g].push(p);
  });

  var html = '<div style="font-family:Arial,sans-serif;max-width:700px;margin:auto;">';
  html += '<div style="text-align:center;margin-bottom:20px;">';
  html += '<div style="font-size:30px;font-weight:900;letter-spacing:0.2em;color:#111;">ÉXTASIS</div>';
  html += '<div style="font-size:12px;color:#666;margin-top:4px;">Av. Gral. José de San Martín 51 · San Rafael, Mendoza · 260 454-7984</div>';
  html += '<div style="font-size:11px;color:#999;margin-top:2px;">Catálogo · ' + new Date().toLocaleDateString('es-AR') + '</div>';
  html += '</div>';

  ['Hombre','Mujer','Accesorios'].forEach(function(g) {
    if (!grupos[g] || !grupos[g].length) return;
    var colorHdr = g === 'Hombre' ? '#1565C0' : g === 'Mujer' ? '#AD1457' : '#4A148C';
    html += '<div style="margin-bottom:18px;">';
    html += '<div style="background:' + colorHdr + ';color:#fff;padding:6px 14px;font-weight:700;font-size:13px;border-radius:6px;margin-bottom:8px;">&#128084; ' + g.toUpperCase() + '</div>';
    html += '<table style="width:100%;border-collapse:collapse;font-size:12px;">';
    html += '<tr style="background:#f0f0f0;"><th style="text-align:left;padding:5px 8px;">Producto</th><th style="text-align:left;padding:5px 8px;">Categoría</th><th style="text-align:right;padding:5px 8px;">Precio lista</th><th style="text-align:right;padding:5px 8px;color:' + colorHdr + ';">Efectivo</th></tr>';
    grupos[g].forEach(function(p, i) {
      var precioLista = p.precio || 0;
      var precioEfectivo = Math.round(precioLista * 0.8);
      var cat = [p.categoria, p.subcategoria].filter(Boolean).join(' / ') || '—';
      var nom = p.producto || '';
      var bg = i % 2 === 0 ? '#fff' : '#f8f8f8';
      html += '<tr style="background:' + bg + ';">';
      html += '<td style="padding:5px 8px;border-bottom:1px solid #eee;">' + nom + '</td>';
      html += '<td style="padding:5px 8px;border-bottom:1px solid #eee;color:#666;">' + cat + '</td>';
      html += '<td style="padding:5px 8px;border-bottom:1px solid #eee;text-align:right;">' + fmt(precioLista) + '</td>';
      html += '<td style="padding:5px 8px;border-bottom:1px solid #eee;text-align:right;color:' + colorHdr + ';font-weight:700;">' + fmt(precioEfectivo) + '</td></tr>';
    });
    html += '</table></div>';
  });
  html += '<div style="text-align:center;font-size:10px;color:#aaa;margin-top:16px;">Precios en pesos argentinos · 20% de descuento en efectivo y transferencia</div>';
  html += '</div>';

  document.getElementById('catalog-print-inner').innerHTML = html;
  document.getElementById('catalog-print-overlay').style.display = 'block';
  toast("Catálogo listo — tocá Imprimir / Guardar PDF", "ok");
  setTimeout(function(){ window.print(); }, 500);
}
</script>
