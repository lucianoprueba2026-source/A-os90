  renderTotals();
  expandMobileCheckoutIfNeeded();
}

/* ══════════════════════════════════════
   CONFIRM SALE
══════════════════════════════════════ */
function confirmSale() {
  if (!S.cart.length) { toast("El carrito está vacío", "warn"); return; }
  const { base, disc, total } = cartCalc();
  /* Validate mixto distribution */
  if (S.method === 'Mixto') {
    var assigned = MIXTO_ITEMS.reduce(function(a,m){ return a + (S.mixtoDistrib[m.key]||0); }, 0);
    if (Math.abs(assigned - total) >= 1) {
      toast("Distribuí el total completo en pago mixto", "warn");
      expandMobileCheckoutIfNeeded();
      return;
    }
  }
  const sale = {
    id: Date.now(), time: mkTime(), date: mkToday(),
    method: S.method, baseTotal: base, discount: disc, total,
    items: S.cart.map(i => ({...i})),
  };
  if (S.method === 'Mixto') {
    sale.mixtoBreakdown = Object.assign({}, S.mixtoDistrib);
  }
  if (S.method === 'Crédito') {
    sale.creditoCuotas = S.creditoCuotas || 1;
  }
  S.sales.unshift(sale);
  S.cart = [];
  /* Reset mixto */
  S.mixtoDistrib = { efectivo:0, transferencia:0, debito:0, credito:0 };
  save();
  renderAll();
  toast("Venta de " + fmt(total) + " registrada 🛒", "ok");
  /* Sync a Supabase en background */
  pushSaleToCloud(sale);
}

