/* ── Product name: multilínea completa ── */
.pr-name {
  white-space: normal !important;
  overflow: visible !important;
  text-overflow: unset !important;
  word-break: break-word !important;
  line-height: 1.35;
  max-width: 100%;
}

/* ── Filter Panel (mobile drawer) ── */
#filter-panel { display: none; position: fixed; inset: 0; z-index: 80; }
#filter-panel.open { display: block; }
#filter-backdrop {
  position: absolute; inset: 0;
  background: rgba(0,0,0,0.48); backdrop-filter: blur(5px);
  animation: fadeIn 0.18s ease;
}
#filter-drawer {
  position: absolute; bottom: 62px; left: 0; right: 0;
  background: var(--bg);
  border-radius: 20px 20px 0 0;
  border-top: 1.5px solid var(--bd2);
  box-shadow: 0 -10px 40px rgba(0,0,0,0.18);
  animation: slideUp 0.3s cubic-bezier(0.16,1,0.3,1);
  max-height: 74vh; overflow-y: auto;
  padding: 6px 16px 28px;
  overscroll-behavior: contain;
}
.fdr-handle {
  width: 38px; height: 4px; background: var(--bd2);
  border-radius: 2px; margin: 10px auto 14px; display: block;
}
.fdr-hdr {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 18px;
}
.fdr-ttl { font-size: 16px; font-weight: 700; font-family: 'Outfit', sans-serif; }
.fdr-close {
  background: var(--bg3); border: none; border-radius: 50%;
  width: 30px; height: 30px; cursor: pointer; font-size: 14px;
  display: flex; align-items: center; justify-content: center;
  color: var(--txt2); transition: all 0.14s;
}
.fdr-close:hover { background: var(--bg4); color: var(--txt); }
.fdr-section { margin-bottom: 20px; }
.fdr-lbl {
  font-size: 9px; font-weight: 800; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--txt3);
  margin-bottom: 10px; display: block;
}
.fdr-chips { display: flex; flex-wrap: wrap; gap: 7px; }
.fdr-chips .filter-chip { font-size: 12px; padding: 6px 14px; }
.fdr-footer { margin-top: 8px; display: flex; gap: 8px; }

/* Filter button - solo mobile */
#prod-filter-btn { display: none; }
@media (max-width: 680px) {
  #prod-filter-btn { display: inline-flex; position: relative; }
}
.filter-dot {
  position: absolute; top: 4px; right: 4px;
  width: 8px; height: 8px; background: var(--ac);
  border-radius: 50%; display: none; border: 2px solid var(--bg);
}
.filter-dot.on { display: block; }

/* ── Total animado ── */
.pos-total-num { transition: transform 0.18s cubic-bezier(0.34,1.56,0.64,1), color 0.18s; }

/* ── Stat pills mejor touch ── */
@media (max-width: 680px) {
  .pos-stats-bar { padding: 6px 10px !important; gap: 6px !important; }
  .pos-stat-pill { min-width: 84px !important; padding: 7px 10px !important; border-radius: var(--r) !important; }
  .psp-val { font-size: 15px !important; }
  .psp-lbl { font-size: 8px !important; }
}

/* ── Gender chips más grandes en mobile ── */
@media (max-width: 760px) {
  .gender-btn { padding: 7px 14px !important; font-size: 12px !important; }
  .gender-ico { font-size: 16px !important; }
}


/* ══ MIXTO PANEL ══ */
.mixto-panel {
  padding: 10px 14px 12px; border-top: 1px solid var(--bd);
  background: var(--bg); flex-shrink: 0;
}
.mixto-panel-lbl {
  font-size: 9px; font-weight: 800; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--txt3);
  display: block; margin-bottom: 8px;
}
.mixto-row {
  display: flex; align-items: center; gap: 7px;
  margin-bottom: 7px;
}
.mixto-ico { font-size: 16px; flex-shrink: 0; }
.mixto-lbl {
  font-size: 12px; font-weight: 600; color: var(--txt2);
  flex: 1; min-width: 0;
}
.mixto-inp {
  width: 100px; flex-shrink: 0;
  background: var(--bg2); border: 1.5px solid var(--bd);
  border-radius: var(--rs); color: var(--txt);
  font-family: 'Outfit', sans-serif; font-size: 13px;
  font-weight: 700; padding: 6px 8px; outline: none;
  text-align: right; transition: border-color 0.15s;
}
.mixto-inp:focus { border-color: var(--ac); }
.mixto-auto {
  flex-shrink: 0; padding: 5px 8px; font-size: 10px;
  font-weight: 700; background: var(--bg3);
  border: 1.5px solid var(--bd); border-radius: var(--rs);
  cursor: pointer; color: var(--txt3); font-family: 'Figtree';
  transition: all 0.14s; white-space: nowrap;
}
.mixto-auto:hover { background: var(--ac-bg); border-color: var(--ac-bd); color: var(--ac); }
.mixto-balance {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8px 10px; border-radius: var(--rs);
  margin-top: 4px; font-size: 12px; font-weight: 700;
  transition: background 0.2s, color 0.2s;
}
.mixto-balance.ok   { background: var(--ok-bg);   color: var(--ok);  border: 1.5px solid var(--ok-bd); }
.mixto-balance.over { background: var(--err-bg);  color: var(--err); border: 1.5px solid var(--err-bd); }
.mixto-balance.under{ background: var(--warn-bg); color: var(--warn); border: 1.5px solid var(--bd); }

/* ══ GREEN CONFIRM BUTTON ══ */
.pos-confirm-btn.green-cart {
  background: #16a34a;
  font-size: 13px;
  gap: 7px;
}
.pos-confirm-btn.green-cart:hover {
  background: #15803d;
  box-shadow: 0 0 0 4px rgba(22,163,74,0.18), 0 4px 16px rgba(22,163,74,0.3);
}
@media (max-width: 680px) {
  .mixto-inp { width: 88px; font-size: 12px; }
  .mixto-row { gap: 5px; }
}

/* ══════════════════════════════════════════════════════
   MOBILE FIXES v3.5 — Nombres · Botones · Distribución
   Correcciones exclusivas de visualización mobile.
   NO modifica lógica JS ni estructura HTML.
══════════════════════════════════════════════════════ */

/* ─────────────────────────────────────────────────────
   PROBLEMA 1: Nombre completo del producto en catálogo
   — Permite wrap, máx 2 líneas, sin cortes abruptos
───────────────────────────────────────────────────── */
@media (max-width: 680px) {

  /* Row: wrap para que el nombre tenga ancho completo */
  .prod-row {
    flex-wrap: wrap !important;
    align-items: flex-start !important;
    padding: 10px 12px !important;
    column-gap: 8px !important;
    row-gap: 4px !important;
  }

  /* Ícono: pequeño, fijo, no se comprime */
  .prod-row .pr-ico {
    font-size: 20px !important;
    width: 24px !important;
    flex-shrink: 0 !important;
    margin-top: 3px !important;
  }

  /* Info: toma todo el ancho de la primera fila (menos el ícono) */
  .prod-row .pr-info {
    flex: 1 1 0 !important;
    min-width: 0 !important;
  }

  /* Nombre: legible, hasta 2 líneas, sin cortes de palabras */
  .prod-row .pr-name {
    font-size: 13px !important;
    white-space: normal !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
    display: -webkit-box !important;
    -webkit-line-clamp: 2 !important;
    -webkit-box-orient: vertical !important;
    word-break: break-word !important;
    line-height: 1.4 !important;
    max-width: 100% !important;
  }

  /* Precios: agrupados a la derecha, alineados con el ícono */
  .prod-row .pr-prices {
    display: flex !important;
    gap: 8px !important;
    flex-shrink: 0 !important;
    align-items: center !important;
    margin-left: auto !important;
  }
  .prod-row .pr-price-block { min-width: 56px !important; text-align: right !important; }
  .prod-row .pr-price-val   { font-size: 13px !important; }
  .prod-row .pr-price-tag   { font-size: 8px !important; }

  /* Acciones: segunda fila completa, botones a la derecha */
  .prod-row .pr-actions {
    flex: 0 0 100% !important;
    width: 100% !important;
    justify-content: flex-end !important;
    gap: 4px !important;
    flex-wrap: nowrap !important;
    margin-top: 0 !important;
  }
  .prod-row .pr-actions .btn-sm {
    min-height: 30px !important;
    padding: 4px 8px !important;
    font-size: 11px !important;
  }
}

/* ─────────────────────────────────────────────────────
   PROBLEMA 2: Botones "Confirmar" y "Cancelar" siempre visibles
   PROBLEMA 3: Distribución vertical correcta
   — Total anclado arriba · Métodos pago scrollables · Botones anclados abajo
───────────────────────────────────────────────────── */
@media (max-width: 768px) {

  /* ── Cart panel: crece para llenar espacio disponible, scroll propio ── */
  .pos-cart-panel {
    flex: 1 1 0 !important;
    min-height: 60px !important;
    max-height: none !important;
    overflow-y: auto !important;
    -webkit-overflow-scrolling: touch !important;
    border-right: none !important;
    border-bottom: 1px solid var(--bd) !important;
  }

  /* ── Checkout panel: columna, altura máxima, overflow CERRADO  ──
     Los hijos flex-shrink:0 no se comprimen (total + botones).
     Solo la zona de métodos de pago tiene scroll interno.          */
  .pos-checkout-panel {
    display: flex !important;
    flex-direction: column !important;
    max-height: 46vh !important;
    overflow: hidden !important;
    flex-shrink: 0 !important;
    border-top: 2px solid var(--bd) !important;
    background: var(--bg) !important;
  }

  /* ── Expander toggle: no se comprime ── */
  .pos-checkout-expander {
    flex-shrink: 0 !important;
  }

  /* ── Total: SIEMPRE visible arriba del panel de checkout ── */
  .pos-total-area {
    flex-shrink: 0 !important;
    padding: 8px 14px 6px !important;
    border-bottom: 1px solid var(--bd) !important;
    background: var(--bg) !important;
  }
  .pos-total-label { font-size: 8px !important; margin-bottom: 2px !important; }
  .pos-total-num   { font-size: 24px !important; margin-bottom: 6px !important; }
  .pos-total-rows  { font-size: 11px !important; }

  /* ── Métodos de pago: ÚNICA zona con scroll vertical ── */
  .pos-checkout-expandable {
    flex: 1 1 auto !important;
    min-height: 0 !important;
    overflow-y: auto !important;
    overflow-x: hidden !important;
    -webkit-overflow-scrolling: touch !important;
  }

  /* ── Botones: SIEMPRE visibles abajo del panel, sin compresión ── */
  .pos-actions {
    flex-shrink: 0 !important;
    display: flex !important;
    flex-direction: row !important;
    padding: 8px 12px 10px !important;
    gap: 6px !important;
    border-top: 2px solid var(--bd) !important;
    background: var(--bg) !important;
    box-shadow: 0 -3px 14px rgba(0,0,0,0.10) !important;
  }
  .pos-confirm-btn {
    flex: 1 !important;
    min-height: 40px !important;
    font-size: 13px !important;
    padding: 9px 8px !important;
    border-radius: 10px !important;
    letter-spacing: 0.01em !important;
  }

  /* ── Carrito vacío: compacto para no desperdiciar espacio ── */
  .pos-cart-empty {
    padding: 14px 12px !important;
    gap: 5px !important;
  }
  .pos-cart-empty-ico { font-size: 24px !important; opacity: 0.35 !important; }
  .pos-cart-empty-txt { font-size: 11px !important; }

  /* ── Header del carrito + items: padding reducido ── */
  .pos-cart-hdr   { padding: 7px 12px !important; }
  .pos-cart-items { padding: 6px 8px !important; }

  /* ── Items del carrito: un poco más compactos ── */
  .pos-item {
    padding: 9px 10px !important;
    margin-bottom: 5px !important;
  }
  .pos-item-name {
    font-size: 13px !important;
    white-space: normal !important;
  }
  .pos-qty-btn  { width: 26px !important; height: 26px !important; }
  .pos-qty-num  { font-size: 13px !important; }

  /* ── Stats bar: reducida pero legible ── */
  .pos-stats-bar  { padding: 5px 8px !important; gap: 5px !important; }
  .pos-stat-pill  { min-width: 78px !important; padding: 6px 9px !important; border-radius: var(--r) !important; }
  .psp-val        { font-size: 14px !important; }
  .psp-lbl        { font-size: 7.5px !important; }
}

/* ═══════════════════════════════════════════════════════════
   MOBILE CRITICAL FIXES — Problemas 1–4
   PROBLEMA 1: carrito vacío compacto
   PROBLEMA 2: métodos de pago siempre visibles
   PROBLEMA 3: botones fijos en la parte inferior
   PROBLEMA 4: input mixto sin pérdida de foco
═══════════════════════════════════════════════════════════ */

/* ── Problema 1: Carrito vacío ultra-compacto ── */
@media (max-width: 768px) {
  .pos-cart-empty {
    padding: 8px 12px !important;
    gap: 3px !important;
    min-height: 0 !important;
  }
  .pos-cart-empty-ico {
    font-size: 16px !important;
    opacity: 0.2 !important;
  }
  .pos-cart-empty-txt {
    font-size: 10px !important;
    color: var(--txt4) !important;
    line-height: 1.3 !important;
    text-align: center;
  }
}

/* ── Problema 2: Métodos de pago siempre visibles ── */
@media (max-width: 768px) {
  /* Ocultar el botón toggle — siempre mostrar el panel */
  .pos-checkout-expander {
    display: none !important;
  }
  /* Forzar visibilidad del panel de pago aunque esté "collapsed" por JS */
  .pos-checkout-expandable,
  .pos-checkout-expandable.collapsed {
    display: block !important;
    overflow-y: auto !important;
    overflow-x: hidden !important;
    -webkit-overflow-scrolling: touch !important;
    flex: 1 1 auto !important;
    min-height: 0 !important;
  }
  /* Reducir espacios del área de total */
  .pos-total-area {
    padding: 5px 12px 4px !important;
    flex-shrink: 0 !important;
  }
  .pos-total-label {
    font-size: 7px !important;
    margin-bottom: 1px !important;
  }
  .pos-total-num {
    font-size: 20px !important;
    margin-bottom: 3px !important;
  }
  .pos-total-rows {
    font-size: 10px !important;
    gap: 1px !important;
  }
  /* Reducir espacios del área de pago */
  .pos-pay-area {
    padding: 5px 10px 5px !important;
    flex-shrink: 0 !important;
  }
  .pos-pay-label {
    font-size: 8px !important;
    margin-bottom: 5px !important;
  }
  /* Altura del panel de checkout — balancear con carrito */
  .pos-checkout-panel {
    max-height: 44vh !important;
    display: flex !important;
    flex-direction: column !important;
  }
  /* Carrito: altura mínima garantizada */
  .pos-cart-panel {
    min-height: 55px !important;
    flex: 1 1 0 !important;
  }
}

/* ── Problema 3: Barra de acciones FIJA en la parte inferior ── */
/* Solo en teléfonos (≤680px) donde existe la bottom-nav */
@media (max-width: 680px) {
  /* Ocultar botones originales (están dentro del checkout panel) */
  .pos-actions {
    display: none !important;
  }
  /* Mostrar barra fija */
  #pos-fixed-action-bar {
    display: flex !important;
  }
  /* Espacio extra para que el contenido no quede tapado */
  #tab-ventas {
    padding-bottom: 64px !important;
  }
}

/* En pantallas más grandes: ocultar barra fija, mostrar botones originales */
@media (min-width: 681px) {
  #pos-fixed-action-bar {
    display: none !important;
  }
}

/* Estilos base de la barra fija (posición + diseño) */
#pos-fixed-action-bar {
  display: none; /* por defecto oculto; media query lo muestra */
  position: fixed;
  bottom: 62px;  /* encima de la bottom-nav (62px de alto) */
  left: 0;
  right: 0;
  z-index: 45;
  background: var(--bg);
  border-top: 2.5px solid var(--bd);
  box-shadow: 0 -4px 24px rgba(0,0,0,0.20);
  padding: 7px 10px 9px;
  gap: 7px;
  align-items: center;
}

/* Sección de total dentro de la barra fija */
.pos-fixed-total {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  min-width: 82px;
}
.pos-fixed-total-label {
  font-size: 8px;
  font-weight: 800;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--txt4);
  line-height: 1;
  margin-bottom: 1px;
}
.pos-fixed-total-num {
  font-size: 19px;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
  font-family: 'Outfit', sans-serif;
  color: var(--txt);
  line-height: 1.1;
}

/* ── FIX LOGIN: ocultar bottom-nav y barra fija durante la pantalla de login ──
   Cuando #app tiene clase "hidden" significa que el login está activo */
#app.hidden ~ #pos-fixed-action-bar { display: none !important; }
#app.hidden ~ nav#bottom-nav        { display: none !important; }
#app.hidden ~ #filter-panel         { display: none !important; }

/* ── Problema 2: Métodos de pago siempre visibles + los 4 botones que entren ── */
@media (max-width: 768px) {
  /* Ocultar toggle, mostrar siempre el panel de métodos */
  .pos-checkout-expander {
    display: none !important;
  }
  .pos-checkout-expandable,
  .pos-checkout-expandable.collapsed {
    display: block !important;
    overflow-y: auto !important;
    overflow-x: hidden !important;
    -webkit-overflow-scrolling: touch !important;
    flex: 1 1 auto !important;
    min-height: 0 !important;
  }
  /* Total area MUY compacta para dar espacio a los botones de pago */
