        '<input class="mixto-inp" type="number" inputmode="decimal" min="0" step="1" ' +
               'value="' + (val > 0 ? val : '') + '" ' +
               'placeholder="$0" ' +
               'oninput="updMixto(\'' + m.key + '\',this.value)" ' +
               'onfocus="this.select()">' +
        '<button class="mixto-auto" onclick="autoMixto(\'' + m.key + '\')">Auto</button>' +
      '</div>';
    }).join('') +
    '<div class="mixto-balance ' + balClass + '">' +
      '<span>' + balMsg + '</span>' +
      '<span style="font-variant-numeric:tabular-nums;">' + fmt(assigned) + ' / ' + fmt(total) + '</span>' +
    '</div>';
  /* Update confirm btn state */
  var btn = document.getElementById('pos-confirm-btn');
  if (btn) {
    btn.style.opacity = isOk ? '1' : '0.55';
    btn.title = isOk ? '' : 'Distribuí el total completo antes de confirmar';
  }
}

/* ── PROBLEMA 4 FIX: Actualiza solo el balance del panel mixto ──
   NO reconstruye los inputs → el teclado móvil NO se cierra
   → el foco del input se mantiene mientras el usuario escribe   ── */
function updateMixtoBalance() {
  var panel = document.getElementById('pos-mixto-panel');
  if (!panel || S.method !== 'Mixto') return;
  var cc = cartCalc(); var total = cc.total;
  var assigned = MIXTO_ITEMS.reduce(function(a,m){ return a + (S.mixtoDistrib[m.key]||0); }, 0);
  var remaining = Math.round((total - assigned) * 100) / 100;
  var isOk   = Math.abs(remaining) < 1;
  var isOver = remaining < -0.5;
  var balClass = isOk ? 'ok' : isOver ? 'over' : 'under';
  var balMsg   = isOk   ? '✓ Monto completo' :
                 isOver ? '⚠ Excede ' + fmt(Math.abs(remaining)) :
                          'Pendiente: ' + fmt(remaining);
  /* Actualizar solo el div de balance — los inputs quedan intactos */
  var balEl = panel.querySelector('.mixto-balance');
  if (balEl) {
    balEl.className = 'mixto-balance ' + balClass;
    balEl.innerHTML =
      '<span>' + balMsg + '</span>' +
      '<span style="font-variant-numeric:tabular-nums;">' + fmt(assigned) + ' / ' + fmt(total) + '</span>';
  }
  /* Actualizar opacidad del botón confirmar (panel + barra fija) */
  var btn = document.getElementById('pos-confirm-btn');
  if (btn) {
    btn.style.opacity = isOk ? '1' : '0.55';
    btn.title = isOk ? '' : 'Distribuí el total completo antes de confirmar';
  }
  var fixBtn = document.getElementById('pos-fixed-confirm-btn');
  if (fixBtn) {
    fixBtn.style.opacity = isOk ? '1' : '0.55';
    fixBtn.title = isOk ? '' : 'Distribuí el total completo antes de confirmar';
  }
}

function updMixto(key, val) {
  S.mixtoDistrib[key] = Math.max(0, parseFloat(val) || 0);
  /* Problema 4 fix: NO llamar renderMixtoPanel() — destruiría el input activo
     y cerraría el teclado móvil. Solo actualizamos el balance. */
  updateMixtoBalance();
}

function autoMixto(key) {
  var cc = cartCalc(); var total = cc.total;
  var assigned = MIXTO_ITEMS.reduce(function(a,m){
    return m.key === key ? a : a + (S.mixtoDistrib[m.key]||0);
  }, 0);
  S.mixtoDistrib[key] = Math.max(0, Math.round(total - assigned));
  /* Actualizar solo el input específico — sin re-render del panel completo */
  var inputs = document.querySelectorAll('.mixto-inp');
  var idx = MIXTO_ITEMS.findIndex(function(m){ return m.key === key; });
  if (inputs[idx]) inputs[idx].value = S.mixtoDistrib[key] || '';
  updateMixtoBalance();
}

