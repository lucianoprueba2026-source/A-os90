function repResetFechas() {
  var d = document.getElementById('rep-desde');
  var h = document.getElementById('rep-hasta');
  if(d) { d.value = ''; }
  if(h) { h.value = ''; }
  repRenderRange('', '');
}

function repFilteredSales(desde, hasta) {
  return S.sales.filter(function(s) {
    if (!desde && !hasta) return true;
    var parts = s.date.split('/');
    if (parts.length !== 3) return true;
    var sDate = parts[2] + '-' + parts[1] + '-' + parts[0];
    if (desde && sDate < desde) return false;
    if (hasta && sDate > hasta) return false;
    return true;
  });
}

function repRenderRange(desde, hasta) {
  var sec = document.getElementById('rep-range-section');
  if (!sec) return;
  if (!desde && !hasta) { sec.innerHTML = ''; return; }

  var sales = repFilteredSales(desde, hasta);
  var totalVentas = sales.reduce(function(a,s){ return a+(s.total||0); }, 0);
  var totalDesc   = sales.reduce(function(a,s){ return a+(s.discount||0); }, 0);
  var totalBase   = sales.reduce(function(a,s){ return a+(s.baseTotal||0); }, 0);

  var metodos = {};
  sales.forEach(function(s) {
    var m = s.method || 'Otro';
    if (!metodos[m]) metodos[m] = { cnt:0, total:0 };
    metodos[m].cnt++;
    metodos[m].total += (s.total||0);
  });

  var prodMap = {};
  sales.forEach(function(s) {
    if (!s.items || !s.items.length) return;
    s.items.forEach(function(item) {
      var k = item.name || '?';
      if (!prodMap[k]) prodMap[k] = { name:k, qty:0, total:0 };
      prodMap[k].qty   += (item.qty||1);
      prodMap[k].total += (item.price||0) * (item.qty||1);
    });
  });
  var prodArr = Object.values(prodMap).sort(function(a,b){ return b.total - a.total; });

  // Convertir fechas YYYY-MM-DD a DD/MM/YYYY para mostrar
  function fmtDate(d) {
    if (!d) return '—';
    var p = d.split('-');
    return p.length === 3 ? p[2]+'/'+p[1]+'/'+p[0] : d;
  }
  var label = fmtDate(desde) + ' → ' + fmtDate(hasta);

  if (sales.length === 0) {
    sec.innerHTML = '<div class="dash-card" style="margin-top:16px;text-align:center;padding:24px;color:var(--txt3);">📊 Sin ventas en el período ' + label + '</div>';
    return;
  }

  var html = '<div class="dash-card" style="margin-top:16px;">';
  html += '<div style="font-weight:700;font-size:13px;margin-bottom:12px;color:var(--txt);">📊 Resumen del período: ' + label + '</div>';
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:10px;margin-bottom:16px;">';
  html += '<div style="background:var(--bg2);border-radius:10px;padding:10px 14px;"><div style="font-size:10px;color:var(--txt3);text-transform:uppercase;letter-spacing:0.05em;">Ventas</div><div style="font-size:17px;font-weight:700;color:var(--txt);">' + fmt(totalVentas) + '</div><div style="font-size:10px;color:var(--txt3);">' + sales.length + ' transacciones</div></div>';
  html += '<div style="background:var(--bg2);border-radius:10px;padding:10px 14px;"><div style="font-size:10px;color:var(--txt3);text-transform:uppercase;letter-spacing:0.05em;">Descuentos</div><div style="font-size:17px;font-weight:700;color:var(--err);">' + fmt(totalDesc) + '</div></div>';
  html += '<div style="background:var(--bg2);border-radius:10px;padding:10px 14px;"><div style="font-size:10px;color:var(--txt3);text-transform:uppercase;letter-spacing:0.05em;">Precio lista</div><div style="font-size:17px;font-weight:700;color:var(--ok);">' + fmt(totalBase) + '</div></div>';
  html += '</div>';

  html += '<div style="font-weight:600;font-size:12px;color:var(--txt);margin-bottom:8px;">Desglose por método de pago</div>';
  html += '<table class="inv-table" style="margin-bottom:16px;"><thead><tr><th>Método</th><th style="text-align:right;">Transacciones</th><th style="text-align:right;">Total</th></tr></thead><tbody>';
  Object.keys(metodos).forEach(function(m) {
    html += '<tr><td>' + m + '</td><td style="text-align:right;">' + metodos[m].cnt + '</td><td style="text-align:right;font-weight:700;">' + fmt(metodos[m].total) + '</td></tr>';
  });
  html += '</tbody></table>';

  if (prodArr.length > 0) {
    html += '<div style="font-weight:600;font-size:12px;color:var(--txt);margin-bottom:8px;">Productos vendidos</div>';
    html += '<table class="inv-table"><thead><tr><th>Producto</th><th style="text-align:right;">Cant.</th><th style="text-align:right;">Total</th></tr></thead><tbody>';
    prodArr.slice(0, 30).forEach(function(p) {
      html += '<tr><td>' + p.name + '</td><td style="text-align:right;">' + p.qty + '</td><td style="text-align:right;font-weight:700;">' + fmt(p.total) + '</td></tr>';
    });
    html += '</tbody></table>';
  }
  html += '</div>';
  sec.innerHTML = html;
}


