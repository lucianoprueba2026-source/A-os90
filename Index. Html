  );
}

function previewImport(input) {
  var file = input.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(e) {
    var content = e.target.result;
    var parsed = [];
    try {
      if (file.name.toLowerCase().endsWith(".json")) { // FIX: case-insensitive
        parsed = JSON.parse(content);
      } else {
        var lines = content.split("\n").filter(function(l){return l.trim();});
        var headers = lines[0].toLowerCase().split(",").map(function(h){return h.trim().replace(/\r/g,"");});
        for (var i=1; i<lines.length; i++) {
          var vals = lines[i].split(",").map(function(v){return v.trim().replace(/\r/g,"");});
          var obj = {};
          headers.forEach(function(h,idx){ obj[h] = vals[idx]||""; });
          parsed.push(obj);
        }
      }
    } catch(err) { toast("Error al leer el archivo","err"); return; }

    var valid = []; var errors = [];
    parsed.forEach(function(row,i) {
      var nombre      = (row.nombre||row.name||"").trim();
      var categoria   = (row.categoria||row.cat||row.category||"").trim();
      var subcategoria = (row.subcategoria||row.sub||row.subcategory||"").trim();
      var producto    = (row.producto||row.product||row.nombre_producto||"").trim();
      var precio      = parseFloat(row.precio||row.price||0);
      if (!nombre)   { errors.push("Fila "+(i+2)+": género (nombre) vacío"); return; }
      if (!["Hombre","Mujer","Accesorios"].includes(nombre)) { errors.push("Fila "+(i+2)+": género inválido \""+nombre+"\""); return; }
      if (!producto)  { errors.push("Fila "+(i+2)+": producto vacío"); return; }
      if (precio < 0) { errors.push("Fila "+(i+2)+": precio inválido"); return; }
      var isDup = S.products.some(function(p){return (p.producto||p.name||'').toLowerCase()===producto.toLowerCase();});
      if (isDup)  { errors.push("Fila "+(i+2)+": \""+producto+"\" ya existe"); return; }
      valid.push({nombre,categoria,subcategoria,producto,precio});
    });

    _importPending = valid;
    var prev = document.getElementById("import-preview");
    var btn  = document.getElementById("import-confirm-btn");
    prev.style.display = "block";
    prev.innerHTML =
      (valid.length ?
        '<div style="padding:10px 12px;background:var(--ok-bg);border-bottom:1px solid var(--ok-bd);"><div class="import-ok-msg">✓ ' + valid.length + ' producto' + (valid.length!==1?"s":"") + ' listos para importar</div></div>' +
        '<table class="import-preview-table"><thead><tr><th>Producto</th><th>Género</th><th>Cat.</th><th>Subcat.</th><th style="text-align:right;">Precio</th></tr></thead><tbody>' +
        valid.map(function(p){
          return '<tr><td style="font-weight:600;">' + p.producto + '</td><td>' + p.nombre + '</td><td>' + p.categoria + '</td><td>' + (p.subcategoria||'—') + '</td><td style="text-align:right;color:var(--ac);font-weight:700;">' + fmt(p.precio) + '</td></tr>';
        }).join("") + '</tbody></table>' : "") +
      (errors.length ?
        '<div style="padding:10px 12px;background:var(--err-bg);border-top:' + (valid.length?"1px solid var(--err-bd)":"none") + ';">' +
        '<div class="import-err-msg">⚠ ' + errors.length + ' error' + (errors.length!==1?"es":"") + '</div>' +
        errors.map(function(e){return '<div class="import-err-item">' + e + '</div>';}).join("") +
        '</div>' : "");
    if (valid.length > 0) btn.classList.remove("hidden");
    else btn.classList.add("hidden");
  };
  reader.readAsText(file);
}

function confirmImport() {
  if (!_importPending.length) return;
  _importPending.forEach(function(p) {
    if (p.categoria && !S.categorias.includes(p.categoria)) { S.categorias.push(p.categoria); }
    if (p.categoria && p.subcategoria) {
      if (!S.subcategorias[p.categoria]) S.subcategorias[p.categoria] = [];
      if (!S.subcategorias[p.categoria].includes(p.subcategoria)) S.subcategorias[p.categoria].push(p.subcategoria);
    }
  });
  var _baseId = Date.now();
  _importPending.forEach(function(p, _i){ S.products.push({id: _baseId + _i, ...p}); });
  save();
  var count = _importPending.length;
  _importPending = [];
  closeModal();
  renderProductos();
  toast(count + " producto" + (count!==1?"s":"") + " importados correctamente", "ok");
}

/* ══════════════════════════════════════
   TOASTS
══════════════════════════════════════ */
var TICO = { ok:"✓", warn:"⚠", err:"✕" };
var TCOL = { ok:"var(--ok)", warn:"var(--warn)", err:"var(--err)" };
function toast(msg, type) {
  type = type || "ok";
  var wrap = document.getElementById("toast-wrap");
  var el = document.createElement("div");
  el.className = "toast";
  el.innerHTML = '<span style="color:' + TCOL[type] + ';font-size:15px;font-weight:800;">' + TICO[type] + '</span><span style="color:var(--txt);">' + msg + '</span>';
  wrap.appendChild(el);
  setTimeout(function() {
    el.style.transition="opacity 0.3s,transform 0.3s";
    el.style.opacity="0"; el.style.transform="translateX(12px)";
    setTimeout(function(){el.remove();},320);
  }, 3000);
}

