    padding: 3px 12px 2px !important;
    flex-shrink: 0 !important;
  }
  .pos-total-label {
    font-size: 7px !important;
    margin-bottom: 0 !important;
  }
  .pos-total-num {
    font-size: 18px !important;
    margin-bottom: 1px !important;
  }
  .pos-total-rows { font-size: 10px !important; }
