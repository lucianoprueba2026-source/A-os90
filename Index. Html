  .pos-checkout-panel {
    flex: 1 1 0 !important;         /* checkout llena TODO el espacio restante */
    max-height: none !important;    /* sin límite: lo que quede es suyo */
    min-height: 165px !important;   /* mínimo para mostrar total + 4 botones */
    display: flex !important;
    flex-direction: column !important;
    overflow: hidden !important;
  }
  /* Carrito vacío ultra-compacto */
  .pos-cart-empty {
    padding: 7px 12px !important;
    gap: 2px !important;
    min-height: 0 !important;
  }
  .pos-cart-empty-ico {
    font-size: 14px !important;
    opacity: 0.2 !important;
  }
  .pos-cart-empty-txt {
    font-size: 10px !important;
    color: var(--txt4) !important;
    line-height: 1.2 !important;
    text-align: center;
