const SUPA_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR1ZWhwanB5Z2t1eXRiZGprZW9oIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzczMzQ1NDgsImV4cCI6MjA5MjkxMDU0OH0.DxmIxvxT5Q5TjRgXm3MDWv9B0KHFfwzcXTBxo34BkVU";
