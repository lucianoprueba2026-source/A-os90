function doBackup() {
  var data = {
    _version: "v3.4",
    _date: new Date().toISOString(),
    products: S.products,
    categorias:    S.categorias,
    subcategorias: S.subcategorias,
    sales:    S.sales,
    expenses: S.expenses,
  };
  var blob = new Blob([JSON.stringify(data, null, 2)], {type:"application/json"});
  var a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = "extasis_backup_" + new Date().toISOString().slice(0,10) + ".json";
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(a.href);
  toast("Backup descargado correctamente 💾", "ok");
}

function triggerRestore() {
  var el = document.getElementById("restore-file-inp");
  if (el) { el.value = ""; el.click(); }
}

function loadBackup(input) {
  var file = input.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(e) {
    try {
      var data = JSON.parse(e.target.result);
      if (!data.products || !data.subcats) { toast("Archivo inválido ⚠️", "err"); return; }
      var dateStr = data._date ? data._date.slice(0,10) : "?";
      if (!confirm("¿Restaurar backup del " + dateStr + "?\nSe reemplazarán todos los datos actuales.")) return;
      S.products = data.products  || [];
      S.categorias    = data.categorias    || data.subcats || JSON.parse(JSON.stringify(INIT_CATEGORIAS));
      S.subcategorias = data.subcategorias || {};
      S.sales    = data.sales     || [];
      S.expenses = data.expenses  || [];
      S.cart     = [];
      save();
      renderAll();
      toast("Backup restaurado: " + S.products.length + " productos, " + S.sales.length + " ventas", "ok");
    } catch(err) {
      toast("Error al leer el backup ✕", "err");
    }
  };
  reader.readAsText(file);
}

