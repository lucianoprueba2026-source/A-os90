══════════════════════════════════════ */
function startVoiceSearch(targetId) {
  var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { toast("Tu navegador no soporta reconocimiento de voz", "warn"); return; }
  var recognition = new SR();
  recognition.lang = "es-AR";
  recognition.interimResults = false;
  recognition.maxAlternatives = 1;
  var btn = document.getElementById("voice-btn-" + targetId);
  if (btn) btn.classList.add("listening");
  recognition.onresult = function(event) {
    var transcript = event.results[0][0].transcript;
    var inp = document.getElementById(targetId);
    if (inp) { inp.value = transcript; inp.dispatchEvent(new Event("input")); }
    if (btn) btn.classList.remove("listening");
    toast("Buscando: \"" + transcript + "\"", "ok");
  };
  recognition.onerror = function() {
    if (btn) btn.classList.remove("listening");
    toast("No se pudo escuchar. Intentá de nuevo.", "warn");
  };
  recognition.onend = function() { if (btn) btn.classList.remove("listening"); };
  recognition.start();
  toast("Escuchando… hablá ahora 🎙️", "ok");
}

